# Python
*.pyc
__pycache__/
.ipynb_checkpoints/

# Virtual environments
venv/
.venv/
test_env/

# OS files
.DS_Store
Thumbs.db

# ==============================================================================
# DATA FILES - Stored on cloud, not in GitHub
# ==============================================================================
# Per committee feedback: Data files should be downloaded from shared cloud folder
# See README.md for download instructions

# Processed data (main enriched dataset is committed)
Data/processed/*.xlsx
Data/processed/*.parquet

# JSON files (large NVD vulnerability data, not needed for dashboard)
Data/JSON\ Files/*.json
!Data/JSON\ Files/.gitkeep

# Raw data
Data/raw/*.csv
Data/raw/*.xlsx
Data/raw/*.dta
Data/raw/*.sas7bdat

# Temporary data files
Data/temp/
Data/cache/

# Keep folder structure with .gitkeep files
!Data/processed/.gitkeep
!Data/raw/.gitkeep

# ==============================================================================
# OUTPUT FILES (optional - uncomment if you don't want outputs in Git)
# ==============================================================================
# outputs/tables/*.csv
# outputs/tables/*.tex
# outputs/figures/*.png
# !outputs/tables/.gitkeep
# !outputs/figures/.gitkeep

# ==============================================================================
# IDE & EDITOR FILES
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==============================================================================
# ENVIRONMENT & SECRETS
# ==============================================================================
.env
.env.local
*.key
wrds_config.ini

# ==============================================================================
# PRESENTATION & DOCUMENT FILES (LOCAL ONLY - NOT IN GITHUB)
# ==============================================================================
# These are personal working documents used for presentations and writing
# They should be kept locally but NOT committed to GitHub
*.docx
*.pptx
*.xlsx

# Markdown files (except README.md which is the main documentation)
*.md
!README.md

# Other working documents
*.txt
!requirements.txt